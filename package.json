{
  "name": "kentobot-api",
  "version": "0.1.0",
  "bin": {
    "kentobot-api": "bin/kentobot-api.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --config vite.config.ts",
    "test:infra": "vitest run --config vitest.config.infra.ts",
    "test:infra:watch": "vitest --config vitest.config.infra.ts",
    "test:infra:coverage": "vitest run --coverage --config vitest.config.infra.ts",
    "cdk": "cdk",
    "deploy:dev": "cdk deploy Dev/* --require-approval never",
    "destroy:dev": "cdk destroy Dev/*",
    "check": "biome check",
    "format": "biome format --write",
    "fix": "biome check --apply"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "24.2.1",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.8",
    "aws-cdk": "2.1023.0",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-mock": "^6.2.1",
    "biome": "^0.3.3",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.6",
    "globals": "^16.0.0",
    "msw": "^2.7.5",
    "supertest": "^7.1.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.32.1",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.24.1",
    "@aws-lambda-powertools/metrics": "^2.24.1",
    "@aws-lambda-powertools/parameters": "^2.23.0",
    "@aws-lambda-powertools/parser": "^2.25.0",
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1000.0",
    "@aws-sdk/client-dynamodb": "^3.1000.0",
    "@aws-sdk/client-eventbridge": "^3.1000.0",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/client-sqs": "^3.1000.0",
    "@aws-sdk/client-ssm": "^3.1000.0",
    "@aws-sdk/lib-dynamodb": "^3.1000.0",
    "@aws-sdk/util-dynamodb": "^3.788.0",
    "@middy/core": "^6.3.2",
    "@types/youtube": "^0.1.2",
    "aws-cdk-lib": "2.208.0",
    "better-status-codes": "^2.1.0",
    "constructs": "^10.4.2",
    "http-errors": "^2.0.0",
    "iso8601-duration": "^2.1.2",
    "node-fetch": "^3.3.2",
    "source-map-support": "^0.5.21",
    "zod": "^4.3.6"
  }
}
